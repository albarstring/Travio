generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model User {
  id                   String    @id @default(cuid())
  email                String   @unique
  password             String
  name                 String
  role                 String
  avatar               String?   @db.MediumText
  bio                  String?   @db.Text
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  location             String?
  notificationSettings Json?
  phone                String?
  privacySettings      Json?
  skills               Json?
  socialLinks          Json?
  website              String?
  isVerified           Boolean   @default(false)
  isActive             Boolean   @default(true)
  isApproved           Boolean   @default(true)
  violationCount       Int       @default(0)
  lastViolationAt      DateTime?
  verificationCode     String?
  verificationExpiry   DateTime?

  // Relations
  taughtCourses Course[]
  enrollments   Enrollment[]
  reviews       Review[]
  payments      Payment[]
  certificates  Certificate[]
  quizAttempts  QuizAttempt[]

  @@map("users")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model Course {
  id           String   @id @default(cuid())
  title        String
  description  String
  instructorId String
  category     String
  thumbnail    String?
  videoUrl     String?
  price        Float
  level        String?
  rating       Float    @default(0)
  reviewCount  Int      @default(0)
  studentCount Int      @default(0)
  isPublished  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  instructor  User         @relation(fields: [instructorId], references: [id])
  sections    Section[]
  enrollments Enrollment[]
  reviews     Review[]
  payments    Payment[]
  certificates Certificate[]
  quizzes     Quiz[]

  @@map("courses")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model Section {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  order       Int
  isPreview   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  course  Course  @relation(fields: [courseId], references: [id])
  lessons Lesson[]

  @@map("sections")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model Lesson {
  id          String   @id @default(cuid())
  sectionId   String
  title       String
  description String
  videoUrl    String
  duration    Int
  order       Int
  content     String?
  isPreview   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  section Section @relation(fields: [sectionId], references: [id])

  @@map("lessons")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model Enrollment {
  id               String    @id @default(cuid())
  userId           String
  courseId         String
  completedLessons String    @db.LongText
  progress         Float     @default(0)
  enrolledAt       DateTime  @default(now())
  completedAt      DateTime?

  // Relations
  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@map("enrollments")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model Review {
  id        String   @id @default(cuid())
  courseId  String
  userId    String
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@map("reviews")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model Payment {
  id            String   @id @default(cuid())
  userId        String
  courseId      String
  amount        Float
  status        String   @default("pending")
  paymentMethod String?
  transactionId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@map("payments")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model Certificate {
  id             String   @id @default(cuid())
  userId         String
  courseId       String
  certificateUrl String?  @db.Text
  issuedAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@map("certificates")
}

/// Quiz model for course quizzes
model Quiz {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  order       Int      @default(0)
  passingScore Float   @default(70)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions   QuizQuestion[]
  attempts    QuizAttempt[]

  @@map("quizzes")
}

/// Quiz questions model
model QuizQuestion {
  id          String   @id @default(cuid())
  quizId      String
  title       String
  description String?
  type        String   @default("multiple-choice") // multiple-choice, true-false, short-answer
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  quiz    Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]

  @@map("quiz_questions")
}

/// Quiz answer options model
model QuizAnswer {
  id         String   @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean  @default(false)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("quiz_answers")
}

/// User quiz attempts
model QuizAttempt {
  id           String   @id @default(cuid())
  userId       String
  quizId       String
  score        Float?
  totalPoints  Int      @default(0)
  earnedPoints Int      @default(0)
  passed       Boolean?
  responses    Json?    // Store user's answers as JSON
  startedAt    DateTime @default(now())
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz  @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([userId, quizId])
  @@map("quiz_attempts")
}
